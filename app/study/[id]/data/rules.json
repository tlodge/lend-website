  "dimensionDefinitions": {
    "topic": {
      "diagnosis": "Stories about diagnosis as a process or event, including being told, understanding what the diagnosis means, and its immediate impact.",
      "life_before": "Stories about a person’s earlier life, identity, work, relationships, routines, or sense of self before dementia became central.",
      "symptoms_leading_to_diagnosis": "Stories about signs, changes, or symptoms noticed before diagnosis.",
      "relationships": "Stories where relationships with other people are central, including family, friends, partners, carers, neighbours, or community connections.",
      "family": "Stories mainly involving relatives, partners, family roles, family support, or family tensions.",
      "friends": "Stories mainly involving friendship, companionship, social circles, or maintaining friendships.",
      "roles": "Stories about what people do for one another, responsibilities, identity roles, caring roles, family roles, work roles, or how roles change as needs change.",
      "living_with_dementia": "Stories about everyday life with dementia and how dementia becomes part of ordinary life.",
      "hobbies": "Stories involving interests, pastimes, creative activities, leisure, enjoyment, or meaningful activities.",
      "routines": "Stories about ordinary days, repeated patterns, habits, familiar activities, and structure.",
      "public_perceptions": "Stories about how other people or wider society view dementia.",
      "stigma": "Stories involving shame, judgement, embarrassment, exclusion, or negative assumptions.",
      "interactions": "Stories about encounters with other people in public, social, work, care, or everyday settings.",
      "misconceptions": "Stories correcting misunderstandings or inaccurate beliefs about dementia.",
      "loss": "Stories where loss is a major emotional or practical theme.",
      "loss_of_a_life": "Stories about losing a previous way of life, identity, future, career, independence, or expected path.",
      "anticipatory_grief": "Stories about grief or sadness before an expected future loss.",
      "daily_challenges": "Stories about practical, emotional, or social difficulties in day-to-day life.",
      "frustrations": "Stories where irritation, difficulty, blocked independence, or repeated obstacles are central.",
      "coping_strategies": "Stories about practical or emotional strategies used to manage, adapt, communicate, remember, stay calm, or get through difficulties.",
      "overcoming": "Stories about progress, resilience, success, confidence, or achieving something despite difficulty.",
      "new_challenges": "Stories about changing circumstances, unfamiliar situations, or newly emerging difficulties.",
      "health_and_social_care": "Stories involving services, professionals, formal care, assessments, or support systems.",
      "resources": "Stories that provide or discuss practical support, information, tools, organisations, or services.",
      "healthcare_interactions": "Stories involving doctors, nurses, hospitals, clinics, social workers, care providers, or appointments.",
      "memories": "Stories centred on remembering, reminiscing, past experiences, or meaningful recollection.",
      "memories_of_a_person": "Stories remembering a specific person or relationship.",
      "memories_of_a_life_lived": "Stories reflecting on someone’s life, history, achievements, places, work, family, or identity.",
      "policies_and_rights": "Stories about systems, laws, entitlements, advocacy, or structural issues affecting people with dementia or carers.",
      "law": "Stories specifically involving legal matters, capacity, rights, duties, powers of attorney, safeguarding, or legal protections.",
      "policies": "Stories involving institutional, government, organisational, or care-system policies.",
      "rights": "Stories about entitlement, fairness, access, dignity, autonomy, or being treated properly.",
      "campaigns": "Stories involving activism, awareness raising, public campaigning, or efforts to change systems.",
      "the_future": "Stories about what may happen later, future needs, decisions, or uncertainty.",
      "anticipated_challenges": "Stories about difficulties expected in the future.",
      "planning": "Stories about preparing, organising care, legal/financial planning, future decisions, or making arrangements.",
      "worries": "Stories centred on anxiety, uncertainty, fear, or concern about what may happen."
    },
    "tone": {
      "formal": "Clear, structured, professional, or official in style.",
      "upbeat": "Positive, energetic, cheerful, or encouraging.",
      "hopeful": "Emphasises possibility, reassurance, resilience, or a better way forward.",
      "funny": "Uses humour, lightness, or amusing moments.",
      "sad": "Emotionally heavy, sorrowful, grief-related, or reflective of pain.",
      "educational": "Designed to explain, teach, inform, or improve understanding.",
      "conversational": "Natural, informal, personal, and easy to follow.",
      "comforting": "Gentle, reassuring, emotionally safe, and supportive.",
      "realistic": "Honest about difficulty without necessarily being negative.",
      "light": "Easy-going, low emotional intensity, relaxing, or not demanding."
    },
    "narrator": {
      "carer": "The story is told by, or primarily represents, someone caring for or supporting a person with dementia.",
      "similar_age": "The narrator is broadly similar in age to the participant.",
      "similar_background_or_culture": "The narrator has a broadly similar cultural, ethnic, religious, language, or background context.",
      "similar_experiences": "The narrator has life experiences, care experiences, diagnosis experiences, or daily circumstances similar to the participant.",
      "different_to_me": "The narrator offers a different perspective or life context from the participant.",
      "any_narrator": "No strong narrator preference."
    }
  },
